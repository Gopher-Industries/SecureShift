# Optional local Docker Compose host-port overrides.
# Most users do not need to copy this file.
#
# If a default host port is already occupied, copy this file to .env and
# uncomment the relevant value. For example, use BACKEND_HOST_PORT=5001 when
# port 5000 is occupied. On macOS, AirPlay Receiver can sometimes use port 5000.

# BACKEND_HOST_PORT=5001
# FRONTEND_HOST_PORT=3001
# MONGODB_HOST_PORT=27018
